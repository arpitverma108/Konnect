# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=konnect
DB_USER=svnbridge_user
DB_PASSWORD=1234

# ─── SVN (WSL Linux paths) ─────────────────────────────────
SVN_REPOS_ROOT=/svn/repos
SVNADMIN_PATH=/usr/bin/svnadmin
SVNLOOK_PATH=/usr/bin/svnlook
SVN_PATH=/usr/bin/svn

# ─── Apache (WSL Linux) ───────────────────────────────────
APACHE_RELOAD_CMD=sudo systemctl restart apache2

# ─── Auth (we will use later) ─────────────────────────────
HTPASSWD_PATH=/home/arpit/svn-config/htpasswd
SVN_REPOS_ROOT=/svn/repos
AUTHZ_PATH=/etc/apache2/dav_svn.authz

# ─── Security ─────────────────────────────────────────────
BCRYPT_ROUNDS=12
