# ─── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=svnbridge
DB_USER=svnbridge_user
DB_PASSWORD=your_secure_password

# ─── SVN Repositories Root ──────────────────────────────────────────────────
# Windows example:
SVN_REPOS_ROOT=C:/svn-data/repos
# Linux example:
# SVN_REPOS_ROOT=/var/svn/repos

# ─── Apache Auth/Authz Files ────────────────────────────────────────────────
# Windows example:
HTPASSWD_PATH=C:/svn-data/conf/htpasswd
AUTHZ_PATH=C:/svn-data/conf/authz
# Linux example:
# HTPASSWD_PATH=/var/svn/conf/htpasswd
# AUTHZ_PATH=/var/svn/conf/authz

# ─── Apache Reload Command ──────────────────────────────────────────────────
# Windows:
APACHE_RELOAD_CMD=httpd -k graceful
# Linux:
# APACHE_RELOAD_CMD=systemctl reload apache2

# ─── SVN Binaries ───────────────────────────────────────────────────────────
# If not on PATH, provide full paths:
# Windows: C:/Program Files/Subversion/bin/svnadmin.exe
SVNADMIN_PATH=svnadmin
SVNLOOK_PATH=svnlook
SVN_PATH=svn

# ─── Security ───────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
